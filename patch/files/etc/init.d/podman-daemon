#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1
NAME=podman-daemon
PROG=/usr/bin/podman

start_service() {
 mkdir -p /run/podman
 procd_open_instance
 procd_set_param command "$PROG" system service -t 0
 procd_set_param respawn
 procd_set_param file /run/podman/podman.sock
 procd_set_param stdout 1
 procd_set_param stderr 1
 procd_close_instance

 # 开机时自动放行容器端口
 collect_ports
}

stop_service() {
 killall podman 2>/dev/null
}

# 自动扫描并放行运行中容器的端口
collect_ports() {
 local ports=""
 local port_line
 for port_line in $(podman ps --format '{{.Ports}}' 2>/dev/null); do
   # 匹配 0.0.0.0:PORT->... 或 [::]:PORT->...
   for p in $(echo "$port_line" | grep -oP '(?:\[::\]|0\.0\.0\.0:)\K\d+'); do
     ports="$ports $p"
   done
 done

 # 去重
 ports=$(echo "$ports" | tr ' ' '\n' | sort -un | tr '\n' ' ')

 for port in $ports; do
   # 检查是否已放行
   if ! iptables -C INPUT -p tcp --dport "$port" -j ACCEPT 2>/dev/null; then
     iptables -I INPUT -p tcp --dport "$port" -j ACCEPT
     ip6tables -I INPUT -p tcp --dport "$port" -j ACCEPT 2>/dev/null
   fi
 done
}
